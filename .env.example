# 複製為 .env.local 並填入實際值（.env.local 已被 gitignore，勿 commit）
# Sanity（公開值，會打包進前端 bundle）
NEXT_PUBLIC_SANITY_PROJECT_ID=your-sanity-project-id
NEXT_PUBLIC_SANITY_DATASET=production

# /studio 後台 Basic Auth（機密，只放 .env.local 與 Vercel 環境變數）
STUDIO_USERNAME=your-studio-username
STUDIO_PASSWORD=your-studio-password

# GA4（選用，設定後 layout.tsx 會載入 GA）
NEXT_PUBLIC_GA_MEASUREMENT_ID=
